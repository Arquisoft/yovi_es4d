# .env
#
# Production/VM defaults.
# IMPORTANT: keep the browser calling the same origin (https://<host>/api/...)
# and let Nginx proxy to the gateway. Do NOT hardcode http://<host>:8000 here,
# otherwise browsers will block requests with "Mixed Content".
MONGODB_URI=mongodb://mongodb_es4d:27017/usersdb

# Frontend build-time API base URL (Vite).
# Leave empty to use window.location.origin at runtime (recommended).
VITE_API_URL=
WEBAPP_VITE_API_URL=

GAME_SERVICE_URL=http://gameservice:8003
USER_SERVICE_URL=http://userservice:8001
AUTH_SERVICE_URL=http://authservice:8002

WEBAPP_PUBLIC_IP=20.188.62.231
WEBAPP_HTTP_PORT=80
WEBAPP_PORT=443

# Webapp (Nginx) -> gateway internal scheme
WEBAPP_GATEWAY_SCHEME=https
GATEWAY_HTTPS=true

GATEWAY_PORT=8000
GAMEY_PORT=4000
PROMETHEUS_PORT=9090
GRAFANA_PORT=9091
GAMEY_BOT_URL=http://localhost:4000
