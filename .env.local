# Local overrides for Docker Compose (keeps the main `.env` intact).
#
# Usage:
#   docker compose --env-file .env.local up --build
#
# Differences vs the default setup:
# - Webapp runs on 8080/8443 to avoid clashes with 80/443.
# - Gateway runs in HTTP mode to simplify local load testing tools.
# - Webapp nginx proxies to the gateway over HTTP.

WEBAPP_HTTP_PORT=8080
WEBAPP_PORT=8443

GATEWAY_HTTPS=false
WEBAPP_GATEWAY_SCHEME=http

