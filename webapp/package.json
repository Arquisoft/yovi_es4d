{
  "name": "webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:services": "concurrently \"npm --prefix ../users/authservice start\" \"npm --prefix ../users start\" \"npm --prefix ../game start\" \"npm --prefix ../friends start\" \"npm --prefix ../gateway start\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e:run": "cucumber-js --import test/e2e/support/setup.mjs --import test/e2e/steps/**/*.mjs test/e2e/features --format progress",
    "test:e2e": "concurrently -k -s first \"npm run start:all\" \"wait-on tcp:5173 tcp:8000 tcp:8001 tcp:8002 tcp:8003 tcp:8004 && npm run test:e2e:run\"",
    "test:e2e:install-browsers": "npx playwright install",
    "start:all": "concurrently \"npm run dev\" \"npm run start:services\"",
    "loadtest": "docker run --rm -e BASE_URL -v \"%cd%/load-tests:/opt/gatling/user-files\" -v \"%cd%/load-tests/results:/opt/gatling/results\" denvazh/gatling:latest -s simulations.WebAppSmokeSimulation",
    "loadtest:mode-selector": "docker run --rm -e BASE_URL -v \"%cd%/load-tests:/opt/gatling/user-files\" -v \"%cd%/load-tests/results:/opt/gatling/results\" denvazh/gatling:latest -s simulations.ModeSelectorLoadSimulation",
    "loadtest:gameboard": "docker run --rm -e BASE_URL -e BOT_MODE -e LOADTEST_USER_EMAIL -e LOADTEST_USER_PASSWORD -e LOADTEST_AUTH_TOKEN -v \"%cd%/load-tests:/opt/gatling/user-files\" -v \"%cd%/load-tests/results:/opt/gatling/results\" denvazh/gatling:latest -s simulations.GameBoardLoadSimulation",
    "loadtest:gameboard:auto-token": "node ./load-tests/run-gameboard-with-auto-token.mjs"
  },
  "dependencies": {
    "gatling": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.4.0",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^22.1.0",
    "playwright": "^1.43.0",
    "postcss": "^8.5.6",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.1",
    "vite-plugin-mkcert": "^1.17.12",
    "vitest": "^4.0.16",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
